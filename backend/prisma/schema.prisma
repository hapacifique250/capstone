generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  APPLICANT
}

enum EducationPathway {
  REB
  TVET
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ADMITTED
  WAITLISTED
  REJECTED
  ACCEPTED
}

enum AdmissionStatus {
  ADMITTED
  WAITLISTED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      UserRole @default(APPLICANT)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicant Applicant?

  @@map("users")
}

model Applicant {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  pathway     EducationPathway
  gender      String
  district    String
  dateOfBirth DateTime

  rebResults   REBResult?
  tvetResults  TVETResult?
  competencies Competency?

  applications Application[]
  admissions   Admission[]

  academicHistory  String?
  extracurriculars String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pathway])
  @@index([district])
  @@map("applicants")
}

model REBResult {
  id          String    @id @default(cuid())
  applicantId String    @unique
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  subjects      String
  totalPoints   Float
  gradeAverage  Float
  yearCompleted Int
  schoolName    String
  schoolCode    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reb_results")
}

model TVETResult {
  id          String    @id @default(cuid())
  applicantId String    @unique
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  trade          String
  specialization String
  level          Int

  competencies  String
  finalGrade    String
  yearCompleted Int
  institution   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tvet_results")
}

model Competency {
  id          String    @id @default(cuid())
  applicantId String    @unique
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  mathSkill      Float @default(0)
  technicalSkill Float @default(0)
  scienceSkill   Float @default(0)
  communication  Float @default(0)
  problemSolving Float @default(0)

  overallScore Float @default(0)

  mappedOnDate  DateTime @default(now())
  mappingSource String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("competencies")
}

model Program {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  college     String

  capacity       Int
  availableSlots Int @default(0)

  acceptsReb  Boolean @default(true)
  acceptsTvet Boolean @default(true)

  minMathSkill      Float @default(0)
  minTechnicalSkill Float @default(0)
  minScienceSkill   Float @default(0)
  minCommunication  Float @default(0)
  minProblemSolving Float @default(0)

  mathWeight           Float @default(0.2)
  technicalWeight      Float @default(0.3)
  scienceWeight        Float @default(0.2)
  communicationWeight  Float @default(0.1)
  problemSolvingWeight Float @default(0.2)

  applications Application[]
  admissions   Admission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([college])
  @@map("programs")
}

model Application {
  id          String    @id @default(cuid())
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  programId String
  program   Program @relation(fields: [programId], references: [id])

  choicePriority Int

  status      ApplicationStatus @default(DRAFT)
  submittedAt DateTime?

  competencyScore  Float?
  eligibilityScore Float?
  finalScore       Float?
  rank             Int?

  admissionProbability Float?
  successProbability   Float?

  admissionStatus AdmissionStatus?
  decisionReason  String?
  decisionDate    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([applicantId, programId, choicePriority])
  @@index([programId])
  @@index([applicantId])
  @@index([status])
  @@index([finalScore])
  @@map("applications")
}

model Admission {
  id          String    @id @default(cuid())
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  programId String
  program   Program @relation(fields: [programId], references: [id])

  status AdmissionStatus
  reason String?

  applicationId String
  finalScore    Float
  rank          Int

  acceptedAt DateTime?
  rejectedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([applicantId, programId])
  @@index([programId])
  @@index([status])
  @@map("admissions")
}

model FairnessAudit {
  id String @id @default(cuid())

  auditDate DateTime @default(now())

  byGender   String
  byDistrict String
  byPathway  String

  totalApplicants Int
  totalAdmitted   Int
  totalRejected   Int

  adverseImpact   Float?
  disparateImpact Float?

  notes String?

  createdAt DateTime @default(now())

  @@map("fairness_audits")
}

model AuditLog {
  id String @id @default(cuid())

  action     String
  entityType String
  entityId   String
  changes    String
  reason     String?

  performedBy String
  performedAt DateTime @default(now())

  @@map("audit_logs")
}

model MLModelMetrics {
  id String @id @default(cuid())

  modelName    String
  modelVersion String

  accuracy  Float
  precision Float
  recall    Float
  f1Score   Float

  trainingDate   DateTime
  evaluationDate DateTime?

  notes String?

  createdAt DateTime @default(now())

  @@map("ml_model_metrics")
}
